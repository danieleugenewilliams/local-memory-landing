# Server
NODE_ENV=development
PORT=3000
DOMAIN=http://localhost:8080

# Stripe Configuration
# VITE_ vars are baked into the frontend at build time by Vite
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_1234567890

# Download Security (Generate with: openssl rand -hex 32)
# VITE_ var — baked into frontend at build time
VITE_DOWNLOAD_SECRET=your_64_character_random_string_here
